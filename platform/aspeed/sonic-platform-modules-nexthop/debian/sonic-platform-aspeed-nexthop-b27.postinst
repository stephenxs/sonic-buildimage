#!/bin/bash
set -e

case "$1" in
    configure)
        if [ -f /host/machine.conf ]; then
            . /host/machine.conf
            DEVICE_NAME="$onie_platform"
        else
            echo "Warning: /host/machine.conf not found, cannot determine platform"
            exit 1
        fi
        DEVICE_DIR="/usr/share/sonic/device/${DEVICE_NAME}"
        if [ -f "${DEVICE_DIR}"/*.whl ]; then
            # Force reinstall to ensure this platform's wheel is installed
            pip3 install --force-reinstall --no-deps "${DEVICE_DIR}"/*.whl
        fi

        # Merge the platform's FEATURE overrides into init_cfg.json.
        INIT_CFG="/etc/sonic/init_cfg.json"
        DEVICE_INIT_CFG="${DEVICE_DIR}/init_cfg.json"
        if [ -f "$INIT_CFG" ] && [ -f "$DEVICE_INIT_CFG" ]; then
            if ! command -v jq >/dev/null 2>&1; then
                echo "Warning: jq not found, skipping merge of $DEVICE_INIT_CFG into $INIT_CFG" >&2
            # Run jq inside the if condition so a failure is contained (script uses `set -e`)
            # and never aborts package configuration.
            elif merged=$(jq -s '.[0] * .[1]' "$INIT_CFG" "$DEVICE_INIT_CFG") && [ -n "$merged" ]; then
                tmp=$(mktemp -p /etc/sonic init_cfg.XXXXXX)
                printf '%s\n' "$merged" > "$tmp"
                mv "$tmp" "$INIT_CFG"
                echo "Merged BMC FEATURE defaults from $DEVICE_INIT_CFG into $INIT_CFG"
            else
                echo "Warning: failed to merge $DEVICE_INIT_CFG into $INIT_CFG" >&2
            fi
        fi
        ;;
esac

#DEBHELPER#
exit 0
